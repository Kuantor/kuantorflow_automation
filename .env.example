# Copy this file to .env and adjust the values. .env is gitignored,
# so the real keyword never reaches the repository.

# Keyword of the KuantorFlow access gate (used by the live site tests).
ACCESS_KEYWORD=password

# Deployed site to smoke-test. Leave empty to skip the live tests.
SITE_URL=https://kuantorflow.pythonanywhere.com

# Path to the kuantorflow app repository (needed by the app tests).
# Default: ../../kuantorflow relative to this repo, i.e. a sibling of
# the 'automation' folder inside !Projects.
# KUANTORFLOW_PATH=C:\Users\38050\Documents\!Projects\kuantorflow

# --- Database backup (backup/backup_db.py) ---
# Credentials for the MySQL 'kuantorflow' database. On PythonAnywhere only
# DB_PASSWORD is needed (host and name default to the account values).
DB_USER=kuantorflow
DB_PASSWORD=your-db-password-here
# Local development overrides:
# DB_HOST=localhost
# DB_NAME=kuantorflow
# MYSQLDUMP_PATH=C:\Program Files\MySQL\MySQL Server 8.0\bin\mysqldump.exe
# BACKUP_KEEP=7
